{
  "info": {
    "_postman_id": "a1b2c3d4-task-manager-api-collection",
    "name": "Task Manager API",
    "description": "Production-grade RESTful API for task management with JWT authentication, role-based access control, and task ownership enforcement.\n\n## Folders\n- **Demo Flow**: Run in order with Collection Runner to see full auth + CRUD + ownership isolation\n- **Manual Operations**: Standalone requests for day-to-day testing\n- **Negative Cases**: Validates error handling (401/400/404)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Demo Flow",
      "description": "Run this folder top-to-bottom with Collection Runner.\nIt registers two users, performs full CRUD, verifies ownership isolation, tests refresh tokens, and cleans up.",
      "item": [
        {
          "name": "Register User A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Has access token', function () {",
                  "    pm.expect(json.accessToken).to.be.a('string').and.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Has refresh token', function () {",
                  "    pm.expect(json.refreshToken).to.be.a('string').and.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Token type is Bearer', function () {",
                  "    pm.expect(json.tokenType).to.eql('Bearer');",
                  "});",
                  "",
                  "pm.test('User has correct email', function () {",
                  "    pm.expect(json.user.email).to.eql(pm.environment.get('emailA').toLowerCase());",
                  "});",
                  "",
                  "pm.environment.set('accessToken', json.accessToken);",
                  "pm.environment.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{emailA}}\",\n  \"password\": \"{{passwordA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
