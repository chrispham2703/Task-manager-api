# ===========================================
# Task Manager API - Configuration Template
# ===========================================
# Copy this file to application.properties and configure your settings

spring.application.name=task-manager-api

# ===========================================
# Database Configuration
# ===========================================
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5433/task_manager}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:postgres}
spring.datasource.driver-class-name=org.postgresql.Driver

# ===========================================
# JPA/Hibernate Configuration
# ===========================================
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.properties.hibernate.jdbc.time_zone=UTC
spring.jpa.open-in-view=false

# ===========================================
# Flyway Configuration
# ===========================================
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

# ===========================================
# Actuator Configuration
# ===========================================
management.endpoints.web.exposure.include=health,info,metrics
management.endpoint.health.show-details=when_authorized

# ===========================================
# Logging
# ===========================================
logging.level.com.taskmanager.api=INFO
logging.level.org.springframework.web=INFO
logging.level.org.flywaydb=INFO

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Change this secret in production!
# Must be at least 256 bits (32 characters)
jwt.secret=${JWT_SECRET:CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_256_BITS_LONG}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}
jwt.refresh-expiration-ms=${JWT_REFRESH_EXPIRATION_MS:604800000}

# ===========================================
# OpenAPI/Swagger Configuration
# ===========================================
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method
